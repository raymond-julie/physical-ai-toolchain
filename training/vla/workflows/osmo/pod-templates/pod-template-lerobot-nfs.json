{
  "spec": {
    "volumes": [
      {
        "name": "lerobot-data",
        "nfs": {
          "server": "192.168.1.100",
          "path": "/srv/lerobot/first_dataset",
          "readOnly": true
        }
      },
      {
        "name": "lerobot-outputs",
        "nfs": {
          "server": "192.168.1.100",
          "path": "/srv/lerobot/outputs"
        }
      }
    ],
    "containers": [
      {
        "name": "{{USER_CONTAINER_NAME}}",
        "volumeMounts": [
          {
            "name": "lerobot-data",
            "mountPath": "/data",
            "readOnly": true
          },
          {
            "name": "lerobot-outputs",
            "mountPath": "/outputs"
          }
        ]
      }
    ]
  }
}
