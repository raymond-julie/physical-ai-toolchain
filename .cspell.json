		"azure-services",
		"microsoft-sample-companies",
		"industry-acronyms",
		"general-technical"
	],
	"caseSensitive": false,
	"useGitignore": true,
	"ignoreRegExpList": [
		"/#.*/g",
		"/^\\s*```[\\s\\S]*?^\\s*```/gm",
		"/^authors?:.*(?:\\r?\\n\\s*-.*)*$/gmi"
	]
