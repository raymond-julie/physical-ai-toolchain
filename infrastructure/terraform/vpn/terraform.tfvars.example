// =============================================================================
// VPN Terraform Variables Example
// =============================================================================
// Copy to terraform.tfvars and customize:  cp terraform.tfvars.example terraform.tfvars
// Full variable reference: variables.tf
// =============================================================================

// Core Configuration (must match 001-iac deployment)
environment     = "dev"
location        = "westus3"
resource_prefix = "yourprefix"
instance        = "001"

// [Optional]
// Point-to-Site (P2S) Certificate Authentication
root_certificate_name = "RoboticsVPNRootCert"

aad_auth_config = {
	should_enable = false
}

// [Optional]
// Generate a self-signed root certificate and paste base64-encoded public key:
//   openssl req -x509 -nodes -newkey rsa:2048 -keyout vpn-root-key.pem -out vpn-root-cert.pem -days 365 -subj "/CN=RoboticsVPNRootCA"
//   openssl x509 -in vpn-root-cert.pem -outform der | base64 | tr -d '\n'
root_certificate_public_data = "YOUR_BASE64_ENCODED_ROOT_CERTIFICATE_HERE"

// Revoke a compromised client certificate by its public SHA-1 thumbprint.
// revoked_client_certificates = [{
//   name       = "hil-lab-01"
//   thumbprint = "0123456789ABCDEF0123456789ABCDEF01234567"
// }]

// [Optional]
// VPN Gateway configuration. Defaults to VpnGw1AZ with all 3 availability zones.
// Adjust zones for regions with fewer availability zones.
// vpn_gateway_config = {
//   sku   = "VpnGw1AZ"
//   zones = ["1", "2", "3"]
// }
